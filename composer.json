{
    "name": "ksfraser/ksf-cache",
    "description": "Production-grade multi-backend caching system with automatic driver detection and fallback support",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kevin Fraser",
            "email": "kevin@ksfraser.com"
        }
    ],
    "require": {
        "php": ">=7.3",
        "psr/log": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "predis/predis": "^2.0"
    },
    "suggest": {
        "predis/predis": "For Redis backend support"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\KsfCache\\": "src/Ksfraser/KsfCache/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\KsfCache\\Tests\\": "tests/"
        }
    }
}
